# Production secrets for docker-compose.prod.yml.
# Copy to .env.prod (gitignored) and fill in. NEVER commit the real file.

# The domain Caddy will serve and auto-provision TLS for.
SITE_ADDRESS=screener.example.com

# Database. Generate a strong password: openssl rand -base64 32
POSTGRES_USER=screener
POSTGRES_PASSWORD=
POSTGRES_DB=screener

# EOD price vendor. See ARCHITECTURE.md §6.
# NOTE: check the vendor's terms before serving this data publicly — free tiers
# generally prohibit REDISTRIBUTION, which is what a public website does.
POLYGON_API_KEY=

# SEC requires a descriptive User-Agent identifying you.
SEC_EDGAR_USER_AGENT="Screener ETL you@example.com"

# Per-IP throttle on the public API.
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
