# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql+psycopg://screener:screener@localhost:5432/screener

# Redis (not used by etl/ yet, reserved for api/)
REDIS_URL=redis://localhost:6379/0

# SEC EDGAR requires a descriptive User-Agent identifying the requester
# https://www.sec.gov/os/webmaster-faq#developers
SEC_EDGAR_USER_AGENT="Screener ETL you@example.com"

# Where bronze (raw) landing data is written; local dir for MVP, swap for
# an s3:// / MinIO path later
BRONZE_PATH=data/bronze
